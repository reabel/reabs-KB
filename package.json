{
  "name": "reabs-kb",
  "version": "1.0.0",
  "description": "KB Reader monorepo — API and frontend app",
  "private": true,
  "workspaces": [
    "kb-reader-api",
    "kb-reader-app",
    "examples/electron-sandbox",
    "examples/nextjs-dashboard",
    "examples/pinia-test",
    "examples/react-recipe",
    "examples/remix-app",
    "examples/remix-tutorial",
    "examples/song-picker",
    "examples/svelte-kit-sample",
    "examples/swagger-sandbox",
    "examples/term-music",
    "examples/three-sandbox",
    "examples/todo",
    "examples/vue-quick-start",
    "examples/vue-store-prototype"
  ],
  "scripts": {
    "api": "npm run start --workspace=kb-reader-api",
    "app": "npm run dev --workspace=kb-reader-app",
    "build": "npm run build --workspace=kb-reader-app",
    "lint": "npm run lint --workspace=kb-reader-app",
    "test": "npm test --workspaces --if-present"
  },
